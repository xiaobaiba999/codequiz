# ============================================
# CodeQuiz 生产环境变量
# 复制此文件为 .env.production 并填入真实值
# Vercel 部署时在 Dashboard > Settings > Environment Variables 中设置
# ============================================

# --- 数据库 (Neon / Supabase) ---
# 从 Neon.tech 或 Supabase 获取 PostgreSQL 连接字符串
# 格式: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=

# --- Redis (Upstash) ---
# 从 Upstash 获取 Redis REST URL (不是 redis:// 格式)
# Upstash 免费版: https://console.upstash.com
REDIS_URL=

# --- JWT 密钥 ---
# 生成方式: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- 判题服务 ---
# Piston API（免费，无需注册）
JUDGE_SERVICE_URL=https://emkc.org/api/v2/piston
JUDGE_SERVICE_TYPE=piston

# --- 前端地址 (CORS) ---
# 部署 Web 后填写，格式: https://your-app.vercel.app
FRONTEND_URL=

# --- 服务器 ---
PORT=3000
NODE_ENV=production
