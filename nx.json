{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "targetDefaults": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  },
  "projects": {
    "api": {
      "root": "packages/api",
      "targets": {
        "dev": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/api",
            "command": "npx tsx watch src/index.ts"
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/api",
            "command": "npx tsc"
          }
        },
        "db:migrate": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/api",
            "command": "npx prisma migrate dev"
          }
        },
        "db:seed": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/api",
            "command": "npx prisma db seed"
          }
        },
        "db:studio": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/api",
            "command": "npx prisma studio"
          }
        }
      }
    },
    "web": {
      "root": "packages/web",
      "targets": {
        "dev": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/web",
            "command": "npx vite"
          }
        },
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/web",
            "command": "npx vite build"
          }
        }
      }
    },
    "mobile": {
      "root": "packages/mobile",
      "targets": {
        "start": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/mobile",
            "command": "npx react-native start"
          }
        },
        "android": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/mobile",
            "command": "npx react-native run-android"
          }
        },
        "ios": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/mobile",
            "command": "npx react-native run-ios"
          }
        }
      }
    },
    "types": {
      "root": "packages/types",
      "targets": {
        "build": {
          "executor": "nx:run-commands",
          "options": {
            "cwd": "packages/types",
            "command": "npx tsc"
          }
        }
      }
    }
  }
}
