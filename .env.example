# 数据库
DATABASE_URL=postgresql://codequiz:codequiz@localhost:5432/codequiz?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 判题服务
JUDGE_SERVICE_URL=https://emkc.org/api/v2/piston
JUDGE_SERVICE_TYPE=piston

# 服务器
PORT=3000
NODE_ENV=development

# 前端地址（CORS 白名单，Vercel 部署后填写）
FRONTEND_URL=https://your-app.vercel.app

# CodePush (移动端)
CODEPUSH_ANDROID_STAGING_KEY=your-android-staging-key
CODEPUSH_ANDROID_PRODUCTION_KEY=your-android-production-key
CODEPUSH_IOS_STAGING_KEY=your-ios-staging-key
CODEPUSH_IOS_PRODUCTION_KEY=your-ios-production-key
