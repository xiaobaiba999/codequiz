{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",
  "builds": [
    { "src": "api/ping.ts", "use": "@vercel/node" },
    { "src": "api/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/ping", "dest": "/api/ping" },
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
