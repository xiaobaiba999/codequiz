{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/((?!test$|ping$).*)", "destination": "/api/test" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ping.ts": {
      "memory": 128
    },
    "api/test.ts": {
      "memory": 256
    }
  }
}
